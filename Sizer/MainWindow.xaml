<Window
    x:Name="window"
    x:Class="Sizer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Sizer"
    mc:Ignorable="d"
    Height="200"
    Width="400"
    Title="Sizer @ FeiLingshu"
    Background="#FF202020"
    Opacity="1"
    WindowStyle="SingleBorderWindow"
    ResizeMode="CanMinimize"
    ShowActivated="True"
    ShowInTaskbar="True"
    Topmost="True">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            UseAeroCaptionButtons="False"
            NonClientFrameEdges="None"
            GlassFrameThickness="0,1,0,0"
            ResizeBorderThickness="0"
            CornerRadius="0">
        </WindowChrome>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid
            Height="30"
            VerticalAlignment="Top"
            HorizontalAlignment="Stretch"
            Background="#FF303030"
            x:Name="TITLE">
            <TextBlock
                Foreground="#FFF0F0F0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontFamily="Consolas, Microsoft YaHei"
                FontSize="16"
                FontWeight="Bold"
                TextAlignment="Left"
                LineHeight="20"
                LineStackingStrategy="BlockLineHeight"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True"
                Margin="10,6,10,4">
                <Run FontSize="16" Foreground="#FFF0F0F0" Text="大小我说了算"/>
                <Run FontSize="12" Foreground="#FF808080" Text="作者：FeiLingshu"/>
            </TextBlock>
            <Border
                Width="30"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Right"
                Margin="0,0,1,0"
                x:Name="CLOSE">
                <Border.Background>
                    <SolidColorBrush x:Name="CloseBG" Color="#FF303030"/>
                </Border.Background>
                <Path
                    Data="M 0,0 L 10,10 M 0,10 L 10,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Stroke="#FFF0F0F0"
                    StrokeThickness="1"
                    IsHitTestVisible="False"/>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Mouse.MouseEnter">
                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                            <Storyboard FillBehavior="HoldEnd">
                                <ColorAnimation 
                                    Storyboard.TargetName="CloseBG"
                                    Storyboard.TargetProperty="Color"
                                    To="#FFC42B1C"
                                    Duration="0:0:0.1">
                                    <ColorAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </ColorAnimation.EasingFunction>
                                </ColorAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="Mouse.MouseLeave">
                        <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                            <Storyboard FillBehavior="HoldEnd">
                                <ColorAnimation 
                                    Storyboard.TargetName="CloseBG"
                                    Storyboard.TargetProperty="Color"
                                    To="#FF303030"
                                    Duration="0:0:0.1">
                                    <ColorAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </ColorAnimation.EasingFunction>
                                </ColorAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
            <Border
                Width="30"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Right"
                Margin="0,0,31,0"
                x:Name="MINI">
                <Border.Background>
                    <SolidColorBrush x:Name="MiniBG" Color="#FF303030"/>
                </Border.Background>
                <Path
                    Data="M 0,0 L 10,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Stroke="#FFF0F0F0"
                    StrokeThickness="1"
                    IsHitTestVisible="False"/>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Mouse.MouseEnter">
                        <BeginStoryboard  HandoffBehavior="SnapshotAndReplace">
                            <Storyboard FillBehavior="HoldEnd">
                                <ColorAnimation 
                                    Storyboard.TargetName="MiniBG"
                                    Storyboard.TargetProperty="Color"
                                    To="#FF404040"
                                    Duration="0:0:0.1">
                                    <ColorAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </ColorAnimation.EasingFunction>
                                </ColorAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="Mouse.MouseLeave">
                        <BeginStoryboard  HandoffBehavior="SnapshotAndReplace">
                            <Storyboard FillBehavior="HoldEnd">
                                <ColorAnimation 
                                    Storyboard.TargetName="MiniBG"
                                    Storyboard.TargetProperty="Color"
                                    To="#FF303030"
                                    Duration="0:0:0.1">
                                    <ColorAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut"/>
                                    </ColorAnimation.EasingFunction>
                                </ColorAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
            <Grid.ContextMenu>
                <ContextMenu>
                    <ContextMenu.Resources>
                        <Style TargetType="ContextMenu">
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="Background" Value="#FF202020"/>
                            <Setter Property="Foreground" Value="#FFC0C0C0"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="#FF404040"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ContextMenu">
                                        <Border Margin="0" Background="Transparent">
                                            <Border 
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="5"
                                                Padding="3"
                                                Margin="5">
                                                <ItemsPresenter/>
                                                <Border.Effect>
                                                    <DropShadowEffect
                                                        BlurRadius="8"
                                                        Color="#FF000000"
                                                        Direction="270"
                                                        Opacity="0.8"
                                                        RenderingBias="Performance"
                                                        ShadowDepth="1"/>
                                                </Border.Effect>
                                            </Border>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Foreground" Value="#FFC0C0C0"/>
                            <Setter Property="Background" Value="#FF202020"/>
                            <Setter Property="FontFamily" Value="Consolas, Microsoft YaHei"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                            <Setter Property="UseLayoutRounding" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border 
                                            Background="{TemplateBinding Background}"
                                            Padding="5,3"
                                            CornerRadius="5">
                                            <StackPanel Orientation="Horizontal">
                                                <ContentPresenter
                                                    ContentSource="Icon"
                                                    Width="10"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,0,5,0"/>
                                                <ContentPresenter
                                                    ContentSource="Header"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FF303030"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="Separator">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <Rectangle
                                            Height="1"
                                            Fill="#FF303030"
                                            HorizontalAlignment="Stretch"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ContextMenu.Resources>
                    <MenuItem
                        Header="保存窗口位置"
                        IsCheckable="True"
                        IsChecked="False"
                        x:Name="Setting_1">
                        <MenuItem.Icon>
                            <Path
                                Data="M 1,5 L 4,8 L 9,1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Stroke="Transparent"
                                StrokeThickness="1"
                                IsHitTestVisible="False"
                                x:Name="SettingIcon_1"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Header="保存配置参数"
                        IsCheckable="True"
                        IsChecked="False"
                        x:Name="Setting_2">
                        <MenuItem.Icon>
                            <Path
                                Data="M 1,5 L 4,8 L 9,1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Stroke="Transparent"
                                StrokeThickness="1"
                                IsHitTestVisible="False"
                                x:Name="SettingIcon_2"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </Grid.ContextMenu>
        </Grid>
        <Grid
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Margin="0,45,0,45"
            x:Name="MainArea">
            <Grid
                Height="60"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Margin="10,0,10,0">
                <TextBlock
                    Foreground="#FFF0F0F0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontFamily="Consolas, Microsoft YaHei"
                    FontSize="14"
                    FontWeight="Bold"
                    TextAlignment="Left"
                    LineStackingStrategy="BlockLineHeight"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Margin="0,2,0,2">
                    <Run Text="窗口信息："/>
                </TextBlock>
                <TextBlock
                    Width="213"
                    Foreground="#FF808080"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontFamily="Consolas, Microsoft YaHei"
                    FontSize="14"
                    FontWeight="Bold"
                    TextAlignment="Left"
                    LineStackingStrategy="BlockLineHeight"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Margin="75,2,0,2"
                    TextTrimming="CharacterEllipsis">
                    <Run Text="句柄：Idle" x:Name="WINHWND"/>
                </TextBlock>
                <TextBlock
                    Width="213"
                    Foreground="#FF808080"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontFamily="Consolas, Microsoft YaHei"
                    FontSize="14"
                    FontWeight="Bold"
                    TextAlignment="Left"
                    LineStackingStrategy="BlockLineHeight"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Margin="75,22,0,2"
                    TextTrimming="CharacterEllipsis">
                    <Run Text="标题：Idle" x:Name="WINTITLE"/>
                </TextBlock>
                <TextBlock
                    Width="213"
                    Foreground="#FF808080"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontFamily="Consolas, Microsoft YaHei"
                    FontSize="14"
                    FontWeight="Bold"
                    TextAlignment="Left"
                    LineStackingStrategy="BlockLineHeight"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Margin="75,42,0,2"
                    TextTrimming="CharacterEllipsis">
                    <Run Text="进程：Idle" x:Name="WINPROC"/>
                </TextBlock>
                <Border
                    BorderBrush="#FF808080"
                    BorderThickness="1"
                    Width="20"
                    Height="20"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    CornerRadius="3"
                    Margin="0,2,62,0"
                    x:Name="GETWIN">
                    <Border.Background>
                        <SolidColorBrush Color="#FF303030"/>
                    </Border.Background>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                <Storyboard FillBehavior="HoldEnd">
                                    <ColorAnimation 
                                        Storyboard.TargetName="GETWIN"
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="#FFC0C0C0"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <ColorAnimation 
                                        Storyboard.TargetName="GETWINSTD"
                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                        To="#FF303030"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                <Storyboard FillBehavior="HoldEnd">
                                    <ColorAnimation 
                                        Storyboard.TargetName="GETWIN"
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="#FF303030"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <ColorAnimation 
                                        Storyboard.TargetName="GETWINSTD"
                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                        To="#FF808080"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Consolas, Microsoft YaHei"
                        FontSize="14"
                        FontWeight="Bold"
                        TextAlignment="Center"
                        LineStackingStrategy="BlockLineHeight"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True"
                        Margin="0,0,0,0"
                        IsHitTestVisible="False"
                        x:Name="GETWINSTD">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="#FF808080"/>
                        </TextBlock.Foreground>
                        <Run Text="?"/>
                    </TextBlock>
                </Border>
                <Border
                    BorderBrush="#FF808080"
                    BorderThickness="1"
                    Width="55"
                    Height="20"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    CornerRadius="3"
                    Margin="0,2,2,0"
                    x:Name="CLEARWIN">
                    <Border.Background>
                        <SolidColorBrush x:Name="CLEARBG" Color="#FF303030"/>
                    </Border.Background>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard  HandoffBehavior="SnapshotAndReplace">
                                <Storyboard FillBehavior="HoldEnd">
                                    <ColorAnimation 
                                        Storyboard.TargetName="CLEARBG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FFC42B1C"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <ColorAnimation 
                                        Storyboard.TargetName="CLEARFG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FFC0C0C0"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard  HandoffBehavior="SnapshotAndReplace">
                                <Storyboard FillBehavior="HoldEnd">
                                    <ColorAnimation 
                                        Storyboard.TargetName="CLEARBG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FF303030"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <ColorAnimation 
                                        Storyboard.TargetName="CLEARFG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FF808080"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Consolas, Microsoft YaHei"
                        FontSize="14"
                        FontWeight="Bold"
                        TextAlignment="Center"
                        LineStackingStrategy="BlockLineHeight"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True"
                        Margin="0,0,0,0"
                        IsHitTestVisible="False">
                        <TextBlock.Foreground>
                            <SolidColorBrush x:Name="CLEARFG" Color="#FF808080"/>
                        </TextBlock.Foreground>
                        <Run Text="Clear"/>
                    </TextBlock>
                </Border>
            </Grid>
            <Grid
                Height="40"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Margin="10,65,10,0">
                <TextBlock
                    Foreground="#FFF0F0F0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    FontFamily="Consolas, Microsoft YaHei"
                    FontSize="14"
                    FontWeight="Bold"
                    TextAlignment="Left"
                    LineStackingStrategy="BlockLineHeight"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Margin="0,2,0,2">
                    <Run Text="目标大小："/>
                </TextBlock>
                <CheckBox
                    Background="#FF202020"
                    BorderBrush="#FF808080"
                    Foreground="#FF808080"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    FontFamily="Consolas, Microsoft YaHei"
                    FontSize="14"
                    FontWeight="Bold"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Margin="0,25,2,0"
                    Padding="4,0,0,1"
                    x:Name="SETFLAG">
                    <TextBlock
                        Foreground="#FF808080"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Consolas, Microsoft YaHei"
                        FontSize="14"
                        FontWeight="Bold"
                        TextAlignment="Center"
                        LineStackingStrategy="BlockLineHeight"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True"
                        Margin="0,0,0,0">
                        <Run Text="包含窗口框架" Foreground="#FF808080" x:Name="SETFLAGSTD"
                             TextDecorations="Underline"/>
                    </TextBlock>
                </CheckBox>
                <TextBox
                    Width="50"
                    Foreground="#FFF0F0F0"
                    Background="#FF303030"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    FontFamily="Consolas, Microsoft YaHei"
                    FontSize="14"
                    FontWeight="Bold"
                    TextAlignment="Left"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Margin="0,2,68,2"
                    IsUndoEnabled="False"
                    UndoLimit="1"
                    AllowDrop="False"
                    InputMethod.IsInputMethodEnabled="False"
                    x:Name="SETWIDTH"/>
                <TextBlock
                    Width="10"
                    Foreground="#FFF0F0F0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    FontFamily="Consolas, Microsoft YaHei"
                    FontSize="14"
                    FontWeight="Bold"
                    TextAlignment="Center"
                    LineStackingStrategy="BlockLineHeight"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Margin="0,2,55,2">
                    <Run Text="×"/>
                </TextBlock>
                <TextBox
                    Width="50"
                    Foreground="#FFF0F0F0"
                    Background="#FF303030"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    FontFamily="Consolas, Microsoft YaHei"
                    FontSize="14"
                    FontWeight="Bold"
                    TextAlignment="Left"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    Margin="0,2,2,2"
                    IsUndoEnabled="False"
                    UndoLimit="1"
                    AllowDrop="False"
                    InputMethod.IsInputMethodEnabled="False"
                    x:Name="SETHEIGHT"/>
                <Border
                    BorderBrush="#FF808080"
                    BorderThickness="1"
                    Width="20"
                    Height="20"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CornerRadius="3"
                    Margin="0,20,0,0"
                    x:Name="SETLEFT">
                    <Border.Background>
                        <SolidColorBrush x:Name="LEFTBG" Color="#FF303030"/>
                    </Border.Background>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard  HandoffBehavior="SnapshotAndReplace">
                                <Storyboard FillBehavior="HoldEnd">
                                    <ColorAnimation 
                                        Storyboard.TargetName="LEFTBG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FFC0C0C0"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <ColorAnimation 
                                        Storyboard.TargetName="LEFTFG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FF303030"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard  HandoffBehavior="SnapshotAndReplace">
                                <Storyboard FillBehavior="HoldEnd">
                                    <ColorAnimation 
                                        Storyboard.TargetName="LEFTBG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FF303030"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <ColorAnimation 
                                        Storyboard.TargetName="LEFTFG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FF808080"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Consolas, Microsoft YaHei"
                        FontSize="14"
                        FontWeight="Bold"
                        TextAlignment="Center"
                        LineStackingStrategy="BlockLineHeight"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True"
                        Margin="0,0,0,1"
                        IsHitTestVisible="False">
                        <TextBlock.Foreground>
                            <SolidColorBrush x:Name="LEFTFG" Color="#FF808080"/>
                        </TextBlock.Foreground>
                        <Run Text="&lt;"/>
                    </TextBlock>
                </Border>
                <Border
                    BorderBrush="#FF808080"
                    BorderThickness="1"
                    Width="20"
                    Height="20"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CornerRadius="3"
                    Margin="25,20,0,0"
                    x:Name="SETADD">
                    <Border.Background>
                        <SolidColorBrush x:Name="ADDBG" Color="#FF303030"/>
                    </Border.Background>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard  HandoffBehavior="SnapshotAndReplace">
                                <Storyboard FillBehavior="HoldEnd">
                                    <ColorAnimation 
                                        Storyboard.TargetName="ADDBG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FF06B025"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <ColorAnimation 
                                        Storyboard.TargetName="ADDFG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FFC0C0C0"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard  HandoffBehavior="SnapshotAndReplace">
                                <Storyboard FillBehavior="HoldEnd">
                                    <ColorAnimation 
                                        Storyboard.TargetName="ADDBG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FF303030"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                    <ColorAnimation 
                                        Storyboard.TargetName="ADDFG"
                                        Storyboard.TargetProperty="Color"
                                        To="#FF808080"
                                        Duration="0:0:0.1">
                                        <ColorAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Consolas, Microsoft YaHei"
